# Supabase (self-hosted at supabase.360ai.link — same project as gmap-reivew-salon)
# Server-only: never expose service_role to the browser.
SUPABASE_URL=https://supabase.360ai.link
SUPABASE_SERVICE_ROLE_KEY=

# Browser-safe anon key (RLS enforced). Required for client-side reads / Realtime / Auth.
NEXT_PUBLIC_SUPABASE_URL=https://supabase.360ai.link
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Twilio — phone OTP for sign-in / sign-up (server-only).
# Message body: "Your GoBeauty Code is:{code}"  From defaults to the shared toll-free.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+18776001886
# Optional alternative to TWILIO_SMS_FROM:
# TWILIO_MESSAGING_SERVICE_SID=

# Optional: HMAC secret for hashing OTP codes (defaults to SUPABASE_SERVICE_ROLE_KEY).
# OTP_HMAC_SECRET=

# Anthropic — powers the photo analysis chat (server-only).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
