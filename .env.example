# Supabase (self-hosted at supabase.360ai.link — same project as gmap-reivew-salon)
# Server-only: never expose service_role to the browser.
SUPABASE_URL=https://supabase.360ai.link
SUPABASE_SERVICE_ROLE_KEY=

# Browser-safe anon key (RLS enforced). Required for client-side reads / Realtime / Auth.
NEXT_PUBLIC_SUPABASE_URL=https://supabase.360ai.link
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic — powers the photo analysis chat (server-only).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
