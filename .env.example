# Supabase — shared with gmap-reivew-salon (same project, same keys).
# Server-only: never expose service_role to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Browser-exposed via NEXT_PUBLIC_ prefix. Required for client-side reads / Realtime.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
